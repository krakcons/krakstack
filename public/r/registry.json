{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "krak",
  "homepage": "https://krakstack.net",
  "items": [
    {
      "name": "data-table",
      "type": "registry:block",
      "title": "Data Table",
      "description": "A URL-state-driven data table with filtering, sorting, column visibility, CSV export, gallery view, grouping, and drag-and-drop row moves.",
      "files": [
        {
          "path": "registry/components/data-table/data-table.tsx",
          "type": "registry:component"
        },
        {
          "path": "registry/components/data-table/messages/en.json",
          "type": "registry:file",
          "target": "./messages/components/data-table/en.json"
        },
        {
          "path": "registry/components/data-table/messages/fr.json",
          "type": "registry:file",
          "target": "./messages/components/data-table/fr.json"
        }
      ],
      "registryDependencies": [
        "badge",
        "card",
        "dropdown-menu",
        "button",
        "input",
        "label",
        "scroll-area",
        "select",
        "table"
      ],
      "dependencies": ["@dnd-kit/core", "@tanstack/react-router", "@tanstack/react-table"]
    },
    {
      "name": "form",
      "type": "registry:block",
      "title": "Form",
      "description": "A TanStack Form setup with reusable field wrappers, text inputs, text areas, selects, multi-selects, key/value editing, file uploads, submit state, and dirty-navigation blocking.",
      "files": [
        {
          "path": "registry/components/form/form.tsx",
          "type": "registry:component"
        },
        {
          "path": "registry/components/form/messages/en.json",
          "type": "registry:file",
          "target": "./messages/components/form/en.json"
        },
        {
          "path": "registry/components/form/messages/fr.json",
          "type": "registry:file",
          "target": "./messages/components/form/fr.json"
        }
      ],
      "registryDependencies": [
        "select",
        "alert-dialog",
        "button",
        "checkbox",
        "field",
        "input",
        "label",
        "textarea"
      ],
      "dependencies": ["lucide-react", "react", "@tanstack/react-form", "@tanstack/react-router"]
    },
    {
      "name": "service-database",
      "title": "Database",
      "description": "An Effect service that provides a Drizzle PostgreSQL client from DATABASE_URL with pg type parsing configured for application-safe date and interval handling.",
      "type": "registry:lib",
      "dependencies": ["effect@beta", "@effect/sql-pg@beta", "pg", "drizzle-orm@beta"],
      "devDependencies": ["drizzle-kit@beta", "@types/pg"],
      "files": [
        {
          "path": "registry/services/database.ts",
          "type": "registry:file",
          "target": "services/database.ts"
        }
      ]
    }
  ]
}
