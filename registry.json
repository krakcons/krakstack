{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "krak",
  "homepage": "https://krakstack.net",
  "items": [
    {
      "name": "data-table",
      "type": "registry:block",
      "title": "Data Table",
      "description": "A simple data table component.",
      "files": [
        {
          "path": "registry/data-table/data-table.tsx",
          "type": "registry:component"
        },
        {
          "path": "registry/data-table/messages/en.json",
          "type": "registry:file",
          "target": "./messages/components/data-table/en.json"
        },
        {
          "path": "registry/data-table/messages/fr.json",
          "type": "registry:file",
          "target": "./messages/components/data-table/fr.json"
        }
      ],
      "registryDependencies": [
        "badge",
        "card",
        "dropdown-menu",
        "button",
        "input",
        "label",
        "scroll-area",
        "select",
        "table"
      ],
      "dependencies": [
        "@dnd-kit/core",
        "@tanstack/react-router",
        "@tanstack/react-table"
      ]
    },
    {
      "name": "form",
      "type": "registry:block",
      "title": "Form",
      "description": "A form builder.",
      "files": [
        {
          "path": "registry/form/form.tsx",
          "type": "registry:component"
        },
        {
          "path": "registry/form/messages/en.json",
          "type": "registry:file",
          "target": "./messages/components/form/en.json"
        },
        {
          "path": "registry/form/messages/fr.json",
          "type": "registry:file",
          "target": "./messages/components/form/fr.json"
        }
      ],
      "registryDependencies": [
        "select",
        "alert-dialog",
        "button",
        "checkbox",
        "field",
        "input",
        "label",
        "textarea"
      ],
      "dependencies": [
        "lucide-react",
        "react",
        "@tanstack/react-form",
        "@tanstack/react-router"
      ]
    }
  ]
}
