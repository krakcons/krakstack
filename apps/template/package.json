{
  "name": "template",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3002",
    "build": "vite build",
    "start": "drizzle-kit migrate && bun run server.ts",
    "preview": "vite preview",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check .",
    "type:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "effect-language-service patch",
    "shadcn:update": "for file in src/components/ui/*.tsx; do bunx shadcn@latest add -y -o $(basename \"$file\" .tsx); done"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/api-key": "^1.6.11",
    "@dnd-kit/core": "^6.3.1",
    "@effect/atom-react": "^4.0.0-beta.66",
    "@effect/sql-pg": "^4.0.0-beta.66",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/react-table": "^8.21.3",
    "@types/bun": "^1.3.14",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-rc.2-e38a2ba",
    "effect": "^4.0.0-beta.66",
    "lucide-react": "^1.16.0",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-qr-code": "^2.0.21",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "^4.0.0-beta.66",
    "@inlang/paraglide-js": "^2.18.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^1.0.0-rc.2-e38a2ba",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
