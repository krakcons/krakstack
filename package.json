{
  "name": "site",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "drizzle-kit migrate && bun run server.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "type:check": "tsc --noEmit",
    "registry:build": "shadcn build",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/services/auth/config.ts --output ./src/db/auth-schema.ts",
    "shadcn:update": "for file in src/components/ui/*.tsx; do bunx shadcn@latest add -y -o $(basename \"$file\" .tsx); done"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/sql-pg": "^4.0.0-beta.60",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.62",
    "@tanstack/react-table": "^8.21.3",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-rc.2-33e80cd",
    "effect": "^4.0.0-beta.60",
    "lucide-react": "^1.14.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@inlang/paraglide-js": "^2.18.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^1.0.0-rc.2-33e80cd",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
