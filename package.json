{
  "name": "site",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3003",
    "build": "vite build",
    "start": "drizzle-kit migrate && bun run server.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "type:check": "tsc --noEmit",
    "registry:build": "shadcn build",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check .",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/services/auth/config.ts --output ./src/db/auth-schema.ts",
    "shadcn:update": "for file in src/components/ui/*.tsx; do bunx shadcn@latest add -y -o $(basename \"$file\" .tsx); done"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1063.0",
    "@base-ui/react": "^1.5.0",
    "@better-auth/api-key": "^1.6.14",
    "@dnd-kit/core": "^6.3.1",
    "@effect/ai-openai-compat": "4.0.0-beta.60",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/sql-pg": "^4.0.0-beta.78",
    "@krak-stack/auth": "^0.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^1.0.0-rc.4-5d5b77c",
    "effect": "^4.0.0-beta.78",
    "lucide-react": "^1.17.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.0.21",
    "shadcn": "^4.10.0",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@inlang/paraglide-js": "^2.18.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
